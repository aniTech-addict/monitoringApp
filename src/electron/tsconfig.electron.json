{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "lib": ["ESNext"],
        "types": ["node"],
        "skipLibCheck": true,

        "outDir": "../../dist-electron",
        "rootDir": "./",

        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitAny": true,
        "strict": true
    },
}